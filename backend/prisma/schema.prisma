generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

enum ClientStatus {
  NEEDS_CONFIGURATION
  LIVE
  PAUSED
  CANCELED
}

enum UserRole {
  CLIENT
  ADMIN
  SUPER_ADMIN
  CLIENT_ADMIN
  CLIENT_STAFF
}

enum OrganizationStatus {
  NEW
  ONBOARDING
  SUBMITTED
  NEEDS_CHANGES
  APPROVED
  PROVISIONING
  TESTING
  LIVE
  PAUSED
}

enum OnboardingStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  NEEDS_CHANGES
  APPROVED
}

enum NumberProvider {
  TWILIO
  VAPI
}

enum PhoneNumberStatus {
  RESERVED
  ACTIVE
  RELEASED
}

enum AiProvider {
  VAPI
  OPENAI
  OTHER
}

enum AgentConfigStatus {
  DRAFT
  ACTIVE
}

enum CallLogOutcome {
  APPOINTMENT_REQUEST
  MESSAGE_TAKEN
  TRANSFERRED
  MISSED
  SPAM
}

enum TestRunStatus {
  PASS
  FAIL
}

enum LeadSource {
  WEB_FORM
  PHONE_CALL
  SMS
}

enum ProspectStatus {
  NEW
  QUALIFIED
  CONTACTED
  NURTURE
  WON
  LOST
}

enum ProspectSource {
  MANUAL
  CSV_IMPORT
  ENRICHED
}

enum SubscriptionPlan {
  STARTER
  PRO
}

enum TeamMembershipRole {
  ADMIN
  MANAGER
  VIEWER
}

enum TeamMembershipStatus {
  ACTIVE
  INVITED
}

enum CallOutcome {
  AI_HANDLED
  TRANSFERRED
  MISSED
  UNKNOWN
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  RECEIVED
  QUEUED
  SENT
  FAILED
  DELIVERED
}

enum CallState {
  RINGING
  CONNECTED
  AI_ACTIVE
  TRANSFERRED
  COMPLETED
}

enum OrgOverrideMode {
  DEFAULT
  FORCE_ON
  FORCE_OFF
}

enum ScaleGateResult {
  PASS
  FAIL
}

model Client {
  id            String         @id @default(cuid())
  name          String
  industry      String?
  status        ClientStatus   @default(NEEDS_CONFIGURATION)
  users         User[]
  subscriptions Subscription[]
  setting       Setting?
  aiConfig      AIConfig?
  calls         Call[]
  leads         Lead[]
  phoneLine     PhoneLine?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Organization {
  id                   String                 @id @default(cuid())
  name                 String
  industry             String?
  status               OrganizationStatus     @default(NEW)
  live                 Boolean                @default(false)
  stripeCustomerId     String?                @unique
  subscriptionStatus   String                 @default("inactive")
  billingActive        Boolean                @default(false)
  includedSeats        Int                    @default(1)
  purchasedSeats       Int                    @default(0)
  routingEngineOverride OrgOverrideMode       @default(DEFAULT)
  autoRecoveryOverride  OrgOverrideMode       @default(DEFAULT)
  smsSendOverride       OrgOverrideMode       @default(DEFAULT)
  slaMonitorOverride    OrgOverrideMode       @default(DEFAULT)
  onboardingApprovedAt DateTime?
  goLiveAt             DateTime?
  users                User[]
  subscriptions        Subscription[]
  onboardingSubmissions OnboardingSubmission[]
  phoneNumbers         PhoneNumber[]
  aiAgentConfigs       AiAgentConfig[]
  callLogs             CallLog[]
  leads                Lead[]
  prospects            Prospect[]
  provisioningChecklist ProvisioningChecklist?
  auditLogs            AuditLog[]
  businessSettings     BusinessSettings?
  configPackage        ConfigPackage?
  aiConfigVersions     AiAgentConfigVersion[]
  configPackageVersions ConfigPackageVersion[]
  testScenarios        TestScenario[]
  testRuns             TestRun[]
  webhookEventLogs     WebhookEventLog[]
  billingWebhookEvents BillingWebhookEvent[]
  demoState            OrganizationDemoState?
  demoAiAttempts       DemoAiAttempt[]
  demoUpgradeSmsThrottle DemoUpgradeSmsThrottle[]
  messageThreads       MessageThread[]
  messages             Message[]
  knowledgeFiles       OrganizationKnowledgeFile[]
  callerProfiles       CallerProfile[]
  autoRecoveryDedupes  AutoRecoveryDedupe[]
  scaleGateDecisions   ScaleGateDecisionLog[]
  memberships          OrganizationMembership[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
}

model Prospect {
  id          String         @id @default(cuid())
  orgId       String?
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  name        String
  business    String
  email       String?
  phone       String?
  website     String?
  industry    String?
  city        String?
  state       String?
  status      ProspectStatus @default(NEW)
  source      ProspectSource @default(MANUAL)
  score       Int?
  scoreReason String?
  tags        String         @default("")
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         UserRole  @default(CLIENT)
  clientId     String?
  client       Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  orgId        String?
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  loginChallenges LoginChallenge[]
  refreshSessions RefreshSession[]
  passwordResetTokens PasswordResetToken[]
  memberships      OrganizationMembership[]
}

model OrganizationMembership {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  role           TeamMembershipRole
  status         TeamMembershipStatus
  invitedEmail   String
  invitedBy      String?
  invitedAt      DateTime?
  acceptedAt     DateTime?
  inviteTokenHash String?
  inviteExpiresAt DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([organizationId, userId])
  @@index([organizationId, status])
  @@index([invitedEmail, status])
  @@index([inviteTokenHash])
}

model Subscription {
  id                   String           @id @default(cuid())
  clientId             String?
  client               Client?          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  orgId                String?
  organization         Organization?    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  plan                 SubscriptionPlan
  stripeCustomerId     String           @unique
  stripeSubscriptionId String           @unique
  status               String
  currentPeriodEnd     DateTime?
  pendingPlan          SubscriptionPlan?
  pendingPlanEffectiveAt DateTime?
  pendingPlanSource    String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

model OnboardingSubmission {
  id             String           @id @default(cuid())
  orgId          String           @unique
  organization   Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  status         OnboardingStatus @default(DRAFT)
  answersJson    String           @default("{}")
  configPackageJson String        @default("{}")
  submittedAt    DateTime?
  reviewedAt     DateTime?
  notesFromAdmin String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model OrganizationKnowledgeFile {
  id              String       @id @default(cuid())
  orgId            String
  organization     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  fileName         String
  mimeType         String
  sizeBytes        Int
  contentText      String
  uploadedByUserId String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([orgId, createdAt])
}

model PhoneNumber {
  id             String          @id @default(cuid())
  orgId          String
  organization   Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  provider       NumberProvider  @default(TWILIO)
  twilioPhoneSid String?
  e164Number     String          @unique
  friendlyName   String?
  status         PhoneNumberStatus @default(RESERVED)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model AiAgentConfig {
  id                String            @id @default(cuid())
  orgId             String            @unique
  organization      Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  provider          AiProvider        @default(VAPI)
  vapiAgentId       String?
  vapiPhoneNumberId String?
  agentId           String?
  apiKeyRef         String?
  voice             String?
  model             String?
  temperature       Float?
  systemPrompt      String?
  toolsJson         String?
  intakeSchemaJson  String?
  toolsEnabledJson  String?
  transferRulesJson String?
  status            AgentConfigStatus @default(DRAFT)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  versions          AiAgentConfigVersion[]
}

model CallLog {
  id             String         @id @default(cuid())
  orgId          String
  organization   Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  providerCallId String?
  fromNumber     String
  toNumber       String
  aiProvider     AiProvider?
  aiSummary      String?
  appointmentRequested Boolean   @default(false)
  leadId         String?
  lead           Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  startedAt      DateTime       @default(now())
  endedAt        DateTime?
  durationSec    Int?
  recordingUrl   String?
  transcript     String?
  outcome        CallLogOutcome @default(MESSAGE_TAKEN)
  rawJson        Json?
  state          CallState?
  ringingAt      DateTime?
  connectedAt    DateTime?
  aiStartedAt    DateTime?
  transferredAt  DateTime?
  completedAt    DateTime?
  routingDecisionJson Json?
  callQualityScore Int?
  callQualityBreakdownJson Json?
  callQualityVersion String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  stateTransitions CallStateTransition[]

  @@unique([orgId, providerCallId])
}

model CallerProfile {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  phoneNumber  String
  totalCalls   Int          @default(0)
  firstCallAt  DateTime
  lastCallAt   DateTime
  lastOutcome  CallLogOutcome?
  flaggedVIP   Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([orgId, phoneNumber])
  @@index([orgId, lastCallAt])
}

model CallStateTransition {
  id           String    @id @default(cuid())
  callLogId    String
  callLog      CallLog   @relation(fields: [callLogId], references: [id], onDelete: Cascade)
  fromState    CallState?
  toState      CallState
  at           DateTime  @default(now())
  metadataJson Json      @default("{}")
  createdAt    DateTime  @default(now())

  @@index([callLogId, at])
}

model AutoRecoveryDedupe {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  phoneNumber  String
  reasonCode   String
  windowBucket String
  createdAt    DateTime     @default(now())

  @@unique([orgId, phoneNumber, reasonCode, windowBucket])
  @@index([orgId, createdAt])
}

model Setting {
  id                 String   @id @default(cuid())
  clientId           String   @unique
  client             Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  businessHoursJson  String   @default("{\"timezone\":\"America/New_York\",\"schedule\":{}}")
  transferNumber     String   @default("")
  servicesJson       String?
  bookingLink        String?
  paused             Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AIConfig {
  id                  String   @id @default(cuid())
  clientId            String   @unique
  client              Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  greetingText        String?
  systemPrompt        String?
  intakeQuestionsJson String?
  transferRulesJson   String?
  afterHoursMessage   String?
  smsEnabled          Boolean  @default(false)
  testMode            Boolean  @default(true)
  updatedAt           DateTime @updatedAt
}

model Call {
  id           String      @id @default(cuid())
  clientId     String
  client       Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fromNumber   String
  toNumber     String
  startedAt    DateTime    @default(now())
  endedAt      DateTime?
  outcome      CallOutcome @default(UNKNOWN)
  recordingUrl String?
  transcript   String?
  summary      String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model PhoneLine {
  id              String   @id @default(cuid())
  clientId        String   @unique
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  provider        String   @default("TWILIO")
  phoneNumber     String?
  twilioIncomingPhoneSid String?
  voiceWebhookUrl String?
  smsWebhookUrl   String?
  capabilitiesJson String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Lead {
  id               String     @id @default(cuid())
  clientId         String?
  client           Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  orgId            String?
  organization     Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  name             String
  business         String
  email            String
  phone            String
  industry         String?
  message          String?
  preferredContact String?
  urgency          String?
  sourcePage       String?
  status           LeadStatus @default(NEW)
  tags             String     @default("")
  notes            String?
  source           LeadSource @default(WEB_FORM)
  dnc              Boolean    @default(false)
  ip               String?
  userAgent        String?
  callLogs         CallLog[]
  messageThreads   MessageThread[]
  messages         Message[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model MessageThread {
  id           String    @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  leadId       String?
  lead         Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  channel      String    @default("SMS")
  contactName  String?
  contactPhone String
  lastMessageAt DateTime @default(now())
  messages     Message[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([orgId, channel, contactPhone])
  @@index([orgId, lastMessageAt])
}

model Message {
  id               String           @id @default(cuid())
  threadId         String
  thread           MessageThread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  orgId            String
  organization     Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  leadId           String?
  lead             Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  direction        MessageDirection
  status           MessageStatus
  body             String
  provider         String           @default("TWILIO")
  providerMessageId String?
  fromNumber       String?
  toNumber         String?
  errorText        String?
  metadataJson     String           @default("{}")
  sentAt           DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([orgId, createdAt])
  @@unique([orgId, providerMessageId])
}

model ProvisioningChecklist {
  id            String   @id @default(cuid())
  orgId         String   @unique
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stepsJson     String   @default("[]")
  derivedStatus String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  orgId       String?
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  actorUserId String
  actorRole   String
  action      String
  metadataJson String  @default("{}")
  createdAt   DateTime @default(now())
}

model BusinessSettings {
  id                      String   @id @default(cuid())
  orgId                   String   @unique
  organization            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  hoursJson               String   @default("{\"timezone\":\"America/New_York\",\"schedule\":{}}")
  afterHoursMode          String   @default("TAKE_MESSAGE")
  transferNumbersJson     String   @default("[]")
  notificationEmailsJson  String   @default("[]")
  notificationPhonesJson  String   @default("[]")
  languagesJson           String   @default("[\"English\"]")
  recordingConsentEnabled Boolean  @default(false)
  smsConsentText          String   @default("")
  timezone                String   @default("America/New_York")
  servicesJson            String   @default("[]")
  policiesJson            String   @default("{}")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model LoginChallenge {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email       String
  codeHash    String
  expiresAt   DateTime
  consumedAt  DateTime?
  attempts    Int      @default(0)
  maxAttempts Int      @default(5)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([email, createdAt])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email      String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([email, createdAt])
}

model ConfigPackage {
  id                String       @id @default(cuid())
  orgId             String       @unique
  organization      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  version           Int          @default(1)
  json              Json
  generatedAt       DateTime     @default(now())
  generatedByUserId String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  versions          ConfigPackageVersion[]
}

model AiAgentConfigVersion {
  id              String       @id @default(cuid())
  orgId           String
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  aiAgentConfigId String
  aiAgentConfig   AiAgentConfig @relation(fields: [aiAgentConfigId], references: [id], onDelete: Cascade)
  version         Int
  configJson      Json
  createdByUserId String?
  createdAt       DateTime     @default(now())

  @@index([orgId, createdAt])
  @@index([aiAgentConfigId, createdAt])
}

model ConfigPackageVersion {
  id              String       @id @default(cuid())
  orgId           String
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  configPackageId String
  configPackage   ConfigPackage @relation(fields: [configPackageId], references: [id], onDelete: Cascade)
  version         Int
  packageJson     Json
  createdByUserId String?
  createdAt       DateTime     @default(now())

  @@index([orgId, createdAt])
  @@index([configPackageId, createdAt])
}

model TestScenario {
  id              String       @id @default(cuid())
  orgId           String
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name            String
  script          String
  expectedOutcome String
  tagsJson        String       @default("[]")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  testRuns        TestRun[]
}

model TestRun {
  id             String       @id @default(cuid())
  orgId          String
  organization   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  scenarioId     String
  scenario       TestScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  providerCallId String?
  status         TestRunStatus
  notes          String?
  createdAt      DateTime     @default(now())
}

model WebhookEventLog {
  id             String       @id @default(cuid())
  orgId          String?
  organization   Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  provider       String
  endpoint       String
  requestId      String?
  statusCode     Int
  reason         String?
  headersJson    String       @default("{}")
  payloadSnippet String       @default("{}")
  createdAt      DateTime     @default(now())
}

model RefreshSession {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash     String   @unique
  expiresAt     DateTime
  revokedAt     DateTime?
  rotatedFromId String?
  familyId      String
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([familyId])
}

model WebhookReplayGuard {
  id         String   @id @default(cuid())
  provider   String
  eventKey   String
  orgId      String?
  receivedAt DateTime @default(now())
  outcome    String
  createdAt  DateTime @default(now())

  @@unique([provider, eventKey, orgId])
  @@index([receivedAt])
  @@index([provider, receivedAt])
}

model BillingWebhookEvent {
  id             String       @id @default(cuid())
  eventId        String       @unique
  eventType      String
  stripeCustomerId String?
  stripeSubscriptionId String?
  orgId          String?
  organization   Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  processed      Boolean      @default(false)
  processingError String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([orgId, createdAt])
  @@index([stripeSubscriptionId, createdAt])
}

model OrganizationDemoState {
  id                    String       @id @default(cuid())
  orgId                 String       @unique
  organization          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  demoStartedAt         DateTime?
  demoEndsAt            DateTime?
  startedByProviderCallId String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}

model DemoAiAttempt {
  id             String       @id @default(cuid())
  orgId          String
  organization   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  providerCallId String
  callerPhone    String?
  attemptedAt    DateTime     @default(now())
  createdAt      DateTime     @default(now())

  @@unique([orgId, providerCallId])
  @@index([orgId, attemptedAt])
}

model DemoUpgradeSmsThrottle {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  callerPhone  String
  lastSentAt   DateTime
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([orgId, callerPhone])
}

model AppConfig {
  id               String   @id @default("singleton")
  demoNumber       String?
  demoVapiAssistantId String?
  demoVapiPhoneNumberId String?
  demoTitle        String?
  demoSubtitle     String?
  demoQuestionsJson String  @default("[]")
  opsThresholdsJson String  @default("{}")
  updatedByUserId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ScaleGateDecisionLog {
  id                   String          @id @default(cuid())
  evaluatedAt          DateTime        @default(now())
  evaluationTimestamp  DateTime
  result               ScaleGateResult
  failingCriteriaJson  Json
  metricsSnapshotJson  Json
  actorUserId          String?
  promotionAttempted   Boolean         @default(false)
  systemicFailTriggered Boolean        @default(false)
  orgId                String?
  organization         Organization?   @relation(fields: [orgId], references: [id], onDelete: SetNull)
  createdAt            DateTime        @default(now())

  @@index([evaluatedAt])
  @@index([result, evaluatedAt])
  @@index([evaluationTimestamp])
}

model DemoCallLog {
  id               String   @id @default(cuid())
  providerCallId   String   @unique
  assistantId      String?
  phoneNumberId    String?
  fromNumber       String
  toNumber         String
  status           String?
  outcome          CallLogOutcome?
  aiSummary        String?
  transcript       String?
  recordingUrl     String?
  successEvaluation Float?
  durationSec      Int?
  startedAt        DateTime @default(now())
  endedAt          DateTime?
  rawJson          Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
