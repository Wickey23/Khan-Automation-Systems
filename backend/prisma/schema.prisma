generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

enum ClientStatus {
  NEEDS_CONFIGURATION
  LIVE
  PAUSED
  CANCELED
}

enum UserRole {
  CLIENT
  ADMIN
  SUPER_ADMIN
  CLIENT_ADMIN
  CLIENT_STAFF
}

enum OrganizationStatus {
  NEW
  ONBOARDING
  SUBMITTED
  NEEDS_CHANGES
  APPROVED
  PROVISIONING
  TESTING
  LIVE
  PAUSED
}

enum OnboardingStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  NEEDS_CHANGES
  APPROVED
}

enum NumberProvider {
  TWILIO
}

enum PhoneNumberStatus {
  RESERVED
  ACTIVE
  RELEASED
}

enum AiProvider {
  VAPI
  OPENAI
  OTHER
}

enum AgentConfigStatus {
  DRAFT
  ACTIVE
}

enum CallLogOutcome {
  APPOINTMENT_REQUEST
  MESSAGE_TAKEN
  TRANSFERRED
  MISSED
  SPAM
}

enum LeadSource {
  WEB_FORM
  PHONE_CALL
  SMS
}

enum SubscriptionPlan {
  STARTER
  PRO
}

enum CallOutcome {
  AI_HANDLED
  TRANSFERRED
  MISSED
  UNKNOWN
}

model Client {
  id            String         @id @default(cuid())
  name          String
  industry      String?
  status        ClientStatus   @default(NEEDS_CONFIGURATION)
  users         User[]
  subscriptions Subscription[]
  setting       Setting?
  aiConfig      AIConfig?
  calls         Call[]
  leads         Lead[]
  phoneLine     PhoneLine?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Organization {
  id                   String                 @id @default(cuid())
  name                 String
  industry             String?
  status               OrganizationStatus     @default(NEW)
  live                 Boolean                @default(false)
  onboardingApprovedAt DateTime?
  goLiveAt             DateTime?
  users                User[]
  subscriptions        Subscription[]
  onboardingSubmissions OnboardingSubmission[]
  phoneNumbers         PhoneNumber[]
  aiAgentConfigs       AiAgentConfig[]
  callLogs             CallLog[]
  leads                Lead[]
  provisioningChecklist ProvisioningChecklist?
  auditLogs            AuditLog[]
  businessSettings     BusinessSettings?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         UserRole  @default(CLIENT)
  clientId     String?
  client       Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  orgId        String?
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Subscription {
  id                   String           @id @default(cuid())
  clientId             String?
  client               Client?          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  orgId                String?
  organization         Organization?    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  plan                 SubscriptionPlan
  stripeCustomerId     String           @unique
  stripeSubscriptionId String           @unique
  status               String
  currentPeriodEnd     DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

model OnboardingSubmission {
  id             String           @id @default(cuid())
  orgId          String           @unique
  organization   Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  status         OnboardingStatus @default(DRAFT)
  answersJson    String           @default("{}")
  configPackageJson String        @default("{}")
  submittedAt    DateTime?
  reviewedAt     DateTime?
  notesFromAdmin String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model PhoneNumber {
  id             String          @id @default(cuid())
  orgId          String
  organization   Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  provider       NumberProvider  @default(TWILIO)
  twilioPhoneSid String?
  e164Number     String          @unique
  friendlyName   String?
  status         PhoneNumberStatus @default(RESERVED)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model AiAgentConfig {
  id                String            @id @default(cuid())
  orgId             String            @unique
  organization      Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  provider          AiProvider        @default(VAPI)
  vapiAgentId       String?
  vapiPhoneNumberId String?
  agentId           String?
  apiKeyRef         String?
  voice             String?
  model             String?
  temperature       Float?
  systemPrompt      String?
  toolsJson         String?
  intakeSchemaJson  String?
  toolsEnabledJson  String?
  transferRulesJson String?
  status            AgentConfigStatus @default(DRAFT)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model CallLog {
  id             String         @id @default(cuid())
  orgId          String
  organization   Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  providerCallId String?
  fromNumber     String
  toNumber       String
  aiProvider     AiProvider?
  aiSummary      String?
  appointmentRequested Boolean   @default(false)
  leadId         String?
  lead           Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  startedAt      DateTime       @default(now())
  endedAt        DateTime?
  durationSec    Int?
  recordingUrl   String?
  transcript     String?
  outcome        CallLogOutcome @default(MESSAGE_TAKEN)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Setting {
  id                 String   @id @default(cuid())
  clientId           String   @unique
  client             Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  businessHoursJson  String   @default("{\"timezone\":\"America/New_York\",\"schedule\":{}}")
  transferNumber     String   @default("")
  servicesJson       String?
  bookingLink        String?
  paused             Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AIConfig {
  id                  String   @id @default(cuid())
  clientId            String   @unique
  client              Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  greetingText        String?
  systemPrompt        String?
  intakeQuestionsJson String?
  transferRulesJson   String?
  afterHoursMessage   String?
  smsEnabled          Boolean  @default(false)
  testMode            Boolean  @default(true)
  updatedAt           DateTime @updatedAt
}

model Call {
  id           String      @id @default(cuid())
  clientId     String
  client       Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fromNumber   String
  toNumber     String
  startedAt    DateTime    @default(now())
  endedAt      DateTime?
  outcome      CallOutcome @default(UNKNOWN)
  recordingUrl String?
  transcript   String?
  summary      String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model PhoneLine {
  id              String   @id @default(cuid())
  clientId        String   @unique
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  provider        String   @default("TWILIO")
  phoneNumber     String?
  twilioIncomingPhoneSid String?
  voiceWebhookUrl String?
  smsWebhookUrl   String?
  capabilitiesJson String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Lead {
  id               String     @id @default(cuid())
  clientId         String?
  client           Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  orgId            String?
  organization     Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  name             String
  business         String
  email            String
  phone            String
  industry         String?
  message          String?
  preferredContact String?
  urgency          String?
  sourcePage       String?
  status           LeadStatus @default(NEW)
  tags             String     @default("")
  notes            String?
  source           LeadSource @default(WEB_FORM)
  dnc              Boolean    @default(false)
  ip               String?
  userAgent        String?
  callLogs         CallLog[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model ProvisioningChecklist {
  id            String   @id @default(cuid())
  orgId         String   @unique
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stepsJson     String   @default("[]")
  derivedStatus String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  orgId       String?
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  actorUserId String
  actorRole   String
  action      String
  metadataJson String  @default("{}")
  createdAt   DateTime @default(now())
}

model BusinessSettings {
  id                      String   @id @default(cuid())
  orgId                   String   @unique
  organization            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  hoursJson               String   @default("{\"timezone\":\"America/New_York\",\"schedule\":{}}")
  afterHoursMode          String   @default("TAKE_MESSAGE")
  transferNumbersJson     String   @default("[]")
  notificationEmailsJson  String   @default("[]")
  notificationPhonesJson  String   @default("[]")
  languagesJson           String   @default("[\"English\"]")
  recordingConsentEnabled Boolean  @default(false)
  smsConsentText          String   @default("")
  timezone                String   @default("America/New_York")
  servicesJson            String   @default("[]")
  policiesJson            String   @default("{}")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
