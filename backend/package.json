{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:migrate:dev": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:push:prod": "prisma db push",
    "seed:admin": "ts-node --transpile-only prisma/seed.ts",
    "backfill:call-leads": "ts-node --transpile-only scripts/backfill-call-leads.ts",
    "backfill:lead-names": "ts-node --transpile-only scripts/backfill-lead-names.ts",
    "harness:billing-edge": "ts-node --transpile-only scripts/billing-edge-harness.ts",
    "harness:stress-webhooks": "ts-node --transpile-only scripts/stress-webhook-replay.ts",
    "phase1:check-env": "ts-node --transpile-only scripts/check-phase1-env.ts",
    "phase1:check-schema": "ts-node --transpile-only scripts/check-phase1-schema.ts",
    "phase1:preflight": "ts-node --transpile-only scripts/check-phase1-preflight.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.10.1",
    "stripe": "^16.12.0",
    "twilio": "^5.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.17.57",
    "@types/nodemailer": "^6.4.17",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
